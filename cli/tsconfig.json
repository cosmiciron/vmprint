{
    "compilerOptions": {
        "target": "ES2020",
        "module": "preserve",
        "moduleResolution": "bundler",
        "baseUrl": ".",
        "declaration": true,
        "outDir": "./dist",
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "rootDir": "./src",
        "paths": {
            "@vmprint/contracts": [
                "../contracts/dist/index.d.ts"
            ],
            "@vmprint/engine": [
                "../engine/dist/index.d.ts"
            ]
        }
    },
    "include": [
        "src/**/*",
        "../engine/src/fontkit.d.ts"
    ],
    "exclude": [
        "node_modules",
        "dist"
    ]
}
