{
  "name": "vmprint",
  "version": "1.0.0",
  "description": "Deterministic typesetting CLI for the programmable web. Convert JSON document streams to bit-perfect PDFs.",
  "author": "cosmiciron",
  "license": "Apache-2.0",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "vmprint": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "npm run clean && tsup",
    "clean": "rimraf dist",
    "dev": "tsx --conditions tsx src/index.ts"
  },
  "devDependencies": {
    "@types/node": "^22.13.1",
    "@vmprint/context-pdf": "file:../contexts/pdf",
    "@vmprint/contracts": "file:../contracts",
    "@vmprint/engine": "file:../engine",
    "@vmprint/local-fonts": "file:../font-managers/local",
    "rimraf": "^6.1.3",
    "commander": "^14.0.3",
    "tsup": "^8.5.1",
    "tsx": "^4.20.5",
    "typescript": "^5.7.3"
  },
  "publishConfig": {
    "access": "public"
  }
}
