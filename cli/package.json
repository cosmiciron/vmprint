{
  "name": "@vmprint/cli",
  "version": "1.0.4",
  "description": "Deterministic typesetting CLI for the programmable web. Convert JSON document streams to bit-perfect PDFs.",
  "author": "cosmiciron",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cosmiciron/vmprint.git",
    "directory": "cli"
  },
  "bugs": {
    "url": "https://github.com/cosmiciron/vmprint/issues"
  },
  "homepage": "https://github.com/cosmiciron/vmprint/tree/main/cli#readme",
  "keywords": [
    "vmprint",
    "cli",
    "pdf",
    "typesetting",
    "document",
    "pagination",
    "layout"
  ],
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "vmprint": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "npm run clean && tsup",
    "clean": "rimraf dist",
    "dev": "tsx --tsconfig tsconfig.dev.json src/index.ts"
  },
  "dependencies": {
    "@vmprint/context-pdf": "^1.0.2",
    "@vmprint/local-fonts": "^1.1.3"
  },
  "devDependencies": {
    "@types/node": "^22.13.1",
    "@vmprint/contracts": "file:../contracts",
    "@vmprint/engine": "file:../engine",
    "rimraf": "^6.1.3",
    "commander": "^14.0.3",
    "tsup": "^8.5.1",
    "tsx": "^4.20.5",
    "typescript": "^5.7.3"
  },
  "publishConfig": {
    "access": "public"
  }
}
