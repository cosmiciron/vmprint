{
  "name": "@vmprint/engine",
  "version": "1.0.0",
  "description": "Deterministic typesetting engine core. Pure-JS, environment-agnostic document composition.",
  "author": "cosmiciron",
  "license": "Apache-2.0",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "tsx": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "source": "src/index.ts",
  "files": [
    "dist",
    "!dist/**/*.spec.js",
    "!dist/**/*.spec.d.ts"
  ],
  "scripts": {
    "build": "npm run clean && tsc",
    "clean": "rimraf dist",
    "check:dist": "npm run build && git diff --exit-code -- dist",
    "test:modules": "tsx --conditions tsx tests/module-extractions.spec.ts",
    "test:ast-compat": "tsx --conditions tsx tests/ast-compatibility.spec.ts",
    "test:flat": "tsx --conditions tsx tests/flat-pipeline.spec.ts",
    "test:strip": "tsx --conditions tsx tests/strip-layout.spec.ts",
    "test:zone-continue": "tsx --conditions tsx tests/zone-map-continue.spec.ts",
    "test:standard-fonts": "tsx --conditions tsx tests/standard-fonts.spec.ts",
    "test:engine": "tsx --conditions tsx tests/engine-regression.spec.ts",
    "test:spatial-ir": "tsx --conditions tsx tests/spatial-ir-regression.spec.ts",
    "test:spatial-ir-engine": "tsx --conditions tsx tests/spatial-ir-engine.spec.ts",
    "test:spatial-ir-strict": "tsx --conditions tsx tests/spatial-ir-strict.spec.ts",
    "test:shared-runtime-font-leak": "tsx --conditions tsx tests/shared-runtime-font-leak.spec.ts",
    "test:perf": "tsx --conditions tsx tests/performance-benchmark.ts",
    "test:perf-watch": "tsx --conditions tsx tests/performance-benchmark.ts --preset=watchlist --repeat=2 --warmup=1",
    "test:update-layout-snapshots": "tsx --conditions tsx tests/engine-regression.spec.ts --update-layout-snapshots",
    "test": "npm run test:modules && npm run test:ast-compat && npm run test:flat && npm run test:strip && npm run test:standard-fonts && npm run test:spatial-ir && npm run test:engine",
    "experiment:actor-comm": "tsx --conditions tsx experiments/proofs/actor-communication.spec.ts",
    "experiment:visual:actor-comm": "tsx --conditions tsx experiments/proofs/actor-communication-visual.ts",
    "experiment:visual:activation-content-only": "tsx --conditions tsx experiments/proofs/actor-activation-content-only-visual.ts",
    "experiment:visual:activation-geometry": "tsx --conditions tsx experiments/proofs/actor-activation-geometry-visual.ts",
    "experiment:visual:activation-oscillation": "tsx --conditions tsx experiments/proofs/actor-activation-oscillation-visual.ts",
    "experiment:visual:clock-cooking": "tsx --conditions tsx experiments/proofs/actor-clock-cooking-visual.ts",
    "experiment:visual:collector": "tsx --conditions tsx experiments/proofs/actor-communication-collector-visual.ts",
    "experiment:visual:inflow": "tsx --conditions tsx experiments/proofs/actor-communication-inflow-collector-visual.ts",
    "experiment:visual:dual-inflow": "tsx --conditions tsx experiments/proofs/actor-communication-dual-inflow-visual.ts",
    "experiment:visual:same-page": "tsx --conditions tsx experiments/proofs/actor-communication-same-page-frontier-visual.ts",
    "experiment:visual:locked-prelude": "tsx --conditions tsx experiments/proofs/actor-communication-locked-prelude-visual.ts"
  },
  "dependencies": {
    "@vmprint/contracts": "file:../contracts",
    "bidi-js": "^1.0.3",
    "dfa": "^1.2.0",
    "fontkit": "^2.0.4",
    "restructure": "^3.0.2",
    "unicode-properties": "^1.4.1",
    "unicode-trie": "^2.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.13.1",
    "@vmprint/local-fonts": "file:../font-managers/local",
    "@vmprint/standard-fonts": "file:../font-managers/standard",
    "rimraf": "^6.1.3",
    "tsx": "^4.21.0",
    "typescript": "^5.7.3"
  },
  "publishConfig": {
    "access": "public"
  }
}
