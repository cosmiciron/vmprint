{
  "name": "@vmprint/engine",
  "version": "0.3.0",
  "description": "Deterministic typesetting engine core. Pure-JS, environment-agnostic document composition.",
  "author": "cosmiciron",
  "license": "Apache-2.0",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "tsx": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "source": "src/index.ts",
  "files": [
    "dist",
    "!dist/**/*.spec.js",
    "!dist/**/*.spec.d.ts"
  ],
  "scripts": {
    "build": "npm run clean && tsc",
    "clean": "rimraf dist",
    "check:dist": "npm run build && git diff --exit-code -- dist",
    "test:modules": "tsx --conditions tsx tests/module-extractions.spec.ts",
    "test:flat": "tsx --conditions tsx tests/flat-pipeline.spec.ts",
    "test:actors": "tsx --conditions tsx tests/actor-communication.spec.ts",
    "test:actors:visual": "tsx --conditions tsx tests/actor-communication-visual.ts",
    "test:actors:collector-visual": "tsx --conditions tsx tests/actor-communication-collector-visual.ts",
    "test:actors:inflow-collector-visual": "tsx --conditions tsx tests/actor-communication-inflow-collector-visual.ts",
    "test:actors:dual-inflow-visual": "tsx --conditions tsx tests/actor-communication-dual-inflow-visual.ts",
    "test:actors:same-page-frontier-visual": "tsx --conditions tsx tests/actor-communication-same-page-frontier-visual.ts",
    "test:actors:locked-prelude-visual": "tsx --conditions tsx tests/actor-communication-locked-prelude-visual.ts",
    "test:standard-fonts": "tsx --conditions tsx tests/standard-fonts.spec.ts",
    "test:engine": "tsx --conditions tsx tests/engine-regression.spec.ts",
    "test:perf": "tsx --conditions tsx tests/performance-benchmark.ts",
    "test:update-layout-snapshots": "tsx --conditions tsx tests/engine-regression.spec.ts --update-layout-snapshots",
    "test": "npm run test:modules && npm run test:flat && npm run test:actors && npm run test:standard-fonts && npm run test:engine"
  },
  "dependencies": {
    "@vmprint/contracts": "file:../contracts",
    "bidi-js": "^1.0.3",
    "dfa": "^1.2.0",
    "fontkit": "^2.0.4",
    "restructure": "^3.0.2",
    "unicode-properties": "^1.4.1",
    "unicode-trie": "^2.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.13.1",
    "@vmprint/local-fonts": "file:../font-managers/local",
    "@vmprint/standard-fonts": "file:../font-managers/standard",
    "rimraf": "^6.1.3",
    "tsx": "^4.21.0",
    "typescript": "^5.7.3"
  },
  "publishConfig": {
    "access": "public"
  }
}
