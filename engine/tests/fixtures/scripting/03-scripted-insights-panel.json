---
methods:
  addInsightsPanel: |
    const headings = vm.report.getHeadings();
    const pageCount = vm.report.getPageCount();
    const inserted = vm.doc.get('insights-panel-title');
    if (inserted) return;
    vm.doc.insertAfter('report-title', [
      {
        type: 'h1',
        content: 'Document Insights',
        properties: {
          sourceId: 'insights-panel-title',
          semanticRole: 'insights-panel-title'
        }
      },
      {
        type: 'p',
        content: `Pages settled: ${pageCount}`,
        properties: {
          sourceId: 'insights-panel-pages',
          semanticRole: 'insights-panel-stat'
        }
      },
      {
        type: 'p',
        content: `Headings discovered: ${headings.length}`,
        properties: {
          sourceId: 'insights-panel-headings',
          semanticRole: 'insights-panel-stat'
        }
      }
    ]);
    vm.requestReplay();
---
{
  "documentVersion": "1.1",
  "layout": {
    "pageSize": { "width": 360, "height": 260 },
    "margins": { "top": 24, "right": 24, "bottom": 24, "left": 24 },
    "fontFamily": "Arimo",
    "fontSize": 12,
    "lineHeight": 1.25
  },
  "fonts": {
    "regular": "Arimo"
  },
  "styles": {
    "p": { "marginBottom": 8, "allowLineSplit": true, "orphans": 2, "widows": 2 },
    "h1": { "fontSize": 18, "fontWeight": "bold", "marginTop": 0, "marginBottom": 12, "keepWithNext": true }
  },
  "onAfterSettle": "addInsightsPanel",
  "elements": [
    {
      "type": "h1",
      "content": "Quarterly Narrative Report",
      "properties": {
        "sourceId": "report-title",
        "semanticRole": "report-title"
      }
    },
    {
      "type": "p",
      "content": "This scripted showcase keeps the authored title intact and augments the document by inserting a generated summary panel immediately after it."
    },
    {
      "type": "h1",
      "content": "Findings",
      "properties": {
        "sourceId": "findings",
        "semanticRole": "h1"
      }
    },
    {
      "type": "p",
      "content": "The findings section gives the script a second heading to count, proving the inserted panel is derived from settled document facts."
    }
  ]
}
