---
methods:
  onReady(): |
    deleteElement("vanishing")
---
{
  "documentVersion": "1.1",
  "layout": {
    "pageSize": "LETTER",
    "margins": { "top": 72, "right": 72, "bottom": 72, "left": 72 },
    "fontFamily": "Times New Roman",
    "fontSize": 16,
    "lineHeight": 1.45
  },
  "styles": {},
  "elements": [
    {
      "type": "p",
      "name": "lead",
      "content": "Lead paragraph: this should remain."
    },
    {
      "type": "p",
      "name": "vanishing",
      "content": "This paragraph should be deleted by a live document helper."
    },
    {
      "type": "p",
      "name": "tail",
      "content": "Tail paragraph: this should follow the lead directly after deletion."
    }
  ]
}
