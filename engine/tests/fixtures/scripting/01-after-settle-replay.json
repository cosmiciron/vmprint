---
methods:
  summarizeHeadings: |
    const summary = vm.doc.get('summary');
    if (!summary) return;
    const headings = vm.report.getHeadings();
    const next = `Heading count: ${headings.length}`;
    if (summary.content !== next) {
      vm.doc.setContent('summary', next);
      vm.requestReplay();
    }
---
{
  "documentVersion": "1.1",
  "layout": {
    "pageSize": { "width": 320, "height": 220 },
    "margins": { "top": 20, "right": 20, "bottom": 20, "left": 20 },
    "fontFamily": "Arimo",
    "fontSize": 12,
    "lineHeight": 1.2
  },
  "fonts": {
    "regular": "Arimo"
  },
  "styles": {
    "p": { "marginBottom": 8, "allowLineSplit": true, "orphans": 2, "widows": 2 },
    "h1": { "fontSize": 18, "fontWeight": "bold", "marginTop": 0, "marginBottom": 12, "keepWithNext": true }
  },
  "onAfterSettle": "summarizeHeadings",
  "elements": [
    {
      "type": "p",
      "content": "Heading count: pending",
      "properties": {
        "sourceId": "summary"
      }
    },
    {
      "type": "h1",
      "content": "Chapter One",
      "properties": {
        "sourceId": "chapter-one",
        "semanticRole": "h1"
      }
    },
    {
      "type": "p",
      "content": "The body paragraph gives the heading something to settle against."
    }
  ]
}
