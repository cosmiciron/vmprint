---
methods:
  target_onMessage(from, msg): |
    if ((from.name === "greeter") && (msg.subject === "decorate")) {
      prepend({
        type: "p",
        name: "leadIn",
        content: "Prepended note: this block now sits before the original actor.",
        properties: {
          style: {
            marginBottom: 14,
            fontStyle: "italic"
          }
        }
      })

      append({
        type: "table",
        name: "detailTable",
        content: "",
        table: {
          headerRows: 1,
          repeatHeader: true,
          columns: [
            { mode: "flex", fr: 2 },
            { mode: "flex", fr: 1 }
          ]
        },
        children: [
          {
            type: "table-row",
            content: "",
            properties: {
              semanticRole: "header"
            },
            children: [
              {
                type: "table-cell",
                content: "Insertion",
                properties: {
                  style: {
                    fontWeight: 700,
                    backgroundColor: "#ebe5d8"
                  }
                }
              },
              {
                type: "table-cell",
                content: "Mode",
                properties: {
                  style: {
                    fontWeight: 700,
                    backgroundColor: "#ebe5d8"
                  }
                }
              }
            ]
          },
          {
            type: "table-row",
            content: "",
            children: [
              {
                type: "table-cell",
                content: "Actor-local"
              },
              {
                type: "table-cell",
                content: "Live append"
              }
            ]
          }
        ]
      })
    }

  greeter_onCreate(): |
    sendMessage("target", {
      subject: "decorate"
    })
---
{
  "documentVersion": "1.1",
  "layout": {
    "pageSize": "LETTER",
    "margins": { "top": 72, "right": 72, "bottom": 72, "left": 72 },
    "fontFamily": "Times New Roman",
    "fontSize": 16,
    "lineHeight": 1.45
  },
  "styles": {
    "table": {
      "marginTop": 12,
      "marginBottom": 12,
      "padding": 0,
      "borderWidth": 0
    },
    "table-cell": {
      "paddingTop": 6,
      "paddingRight": 8,
      "paddingBottom": 6,
      "paddingLeft": 8,
      "borderWidth": 0.8,
      "borderColor": "#7f7464"
    }
  },
  "elements": [
    {
      "type": "p",
      "name": "target",
      "content": "Original actor body: it should stay in the middle, between the prepended and appended live inserts."
    },
    {
      "type": "p",
      "name": "greeter",
      "content": "Sender element: it triggers actor-local prepend and append.",
      "properties": {
        "style": {
          "marginTop": 18
        }
      }
    },
    {
      "type": "p",
      "name": "tail",
      "content": "Tail paragraph: the flow should keep going after the appended live actor."
    }
  ]
}
