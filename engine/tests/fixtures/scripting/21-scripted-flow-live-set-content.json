---
methods:
  onReady(): |
    sendMessage("controller", {
      subject: "promote"
    })

  controller_onMessage(from, msg): |
    if (msg.subject === "promote") {
      setContent("zoned-follow", "Nested scripted host updated this zone child live.")
      setContent(self, "Controller element: message handled.")
    }
---
{
  "documentVersion": "1.1",
  "layout": {
    "pageSize": "LETTER",
    "margins": { "top": 72, "right": 72, "bottom": 72, "left": 72 },
    "fontFamily": "Times New Roman",
    "fontSize": 16,
    "lineHeight": 1.45
  },
  "styles": {},
  "elements": [
    {
      "type": "p",
      "name": "controller",
      "content": "Controller element: waiting.",
      "properties": {
        "onMessage": "controller_onMessage"
      }
    },
    {
      "type": "zone-map",
      "content": "",
      "name": "zone-host",
      "zoneLayout": {
        "columns": [
          { "mode": "flex", "fr": 2 },
          { "mode": "flex", "fr": 1 }
        ],
        "gap": 18,
        "frameOverflow": "move-whole",
        "worldBehavior": "fixed"
      },
      "zones": [
        {
          "id": "main",
          "elements": [
            {
              "type": "p",
              "name": "zoned-follow",
              "content": "Zone child starts untouched."
            }
          ]
        },
        {
          "id": "side",
          "elements": [
            {
              "type": "p",
              "name": "sidebar-note",
              "content": "Sidebar stays present."
            }
          ]
        }
      ]
    }
  ]
}
