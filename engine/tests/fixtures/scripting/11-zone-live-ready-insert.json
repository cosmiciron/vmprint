---
methods:
  onReady(): |
    insertBefore("zoned-anchor", [
      {
        type: "p",
        name: "zone-prelude",
        content: "Zone prelude inserted live."
      }
    ])

    insertAfter("zoned-anchor", [
      {
        type: "p",
        name: "zone-epilogue",
        content: "Zone epilogue inserted live."
      }
    ])
---
{
  "documentVersion": "1.1",
  "layout": {
    "pageSize": "LETTER",
    "margins": { "top": 72, "right": 72, "bottom": 72, "left": 72 },
    "fontFamily": "Times New Roman",
    "fontSize": 16,
    "lineHeight": 1.45
  },
  "styles": {},
  "elements": [
    {
      "type": "p",
      "name": "lead",
      "content": "Lead paragraph above zone host."
    },
    {
      "type": "zone-map",
      "content": "",
      "name": "zone-host",
      "zoneLayout": {
        "columns": [
          { "mode": "flex", "fr": 2 },
          { "mode": "flex", "fr": 1 }
        ],
        "gap": 18,
        "frameOverflow": "move-whole",
        "worldBehavior": "fixed"
      },
      "zones": [
        {
          "id": "main",
          "elements": [
            {
              "type": "p",
              "name": "zoned-anchor",
              "content": "Zone anchor stays centered."
            },
            {
              "type": "p",
              "name": "zoned-follow",
              "content": "Zone follow stays after inserts."
            }
          ]
        },
        {
          "id": "side",
          "elements": [
            {
              "type": "p",
              "name": "sidebar-note",
              "content": "Sidebar remains steady."
            }
          ]
        }
      ]
    },
    {
      "type": "p",
      "name": "tail",
      "content": "Tail paragraph after zone host."
    }
  ]
}
