{
  "documentVersion": "1.1",
  "layout": {
    "pageSize": { "width": 380, "height": 360 },
    "margins": { "top": 28, "right": 28, "bottom": 28, "left": 28 },
    "fontFamily": "Arimo",
    "fontSize": 10.5,
    "lineHeight": 1.28
  },
  "fonts": { "regular": "Arimo", "bold": "Arimo" },
  "styles": {
    "h1": { "fontSize": 17, "fontWeight": "bold", "marginBottom": 9 },
    "list": { "marginTop": 3, "marginBottom": 7 },
    "list-marker": { "fontWeight": "bold" }
  },
  "elements": [
    { "type": "h1", "content": "Native List Custom Markers" },
    {
      "type": "list",
      "list": {
        "kind": "unordered",
        "markerText": ">>",
        "indent": 32,
        "markerWidth": 18,
        "markerGap": 7,
        "itemSpacing": 4,
        "levels": [
          { "kind": "unordered", "markerText": ">>", "indent": 32, "markerWidth": 18, "markerGap": 7 },
          { "kind": "unordered", "markerText": "✓", "indent": 25, "markerWidth": 14, "markerGap": 6 },
          { "kind": "unordered", "markerText": "◆", "indent": 22, "markerWidth": 14, "markerGap": 5 }
        ]
      },
      "properties": { "sourceId": "custom-marker-root-list" },
      "children": [
        {
          "type": "list-item",
          "content": "Root item uses a literal custom marker generated by the list actor.",
          "properties": { "sourceId": "custom-marker-root-one" },
          "children": [
            {
              "type": "list",
              "properties": { "sourceId": "custom-marker-check-list" },
              "children": [
                {
                  "type": "list-item",
                  "content": "Nested item inherits a check marker from level defaults.",
                  "properties": { "sourceId": "custom-marker-check-one" },
                  "children": [
                    {
                      "type": "list",
                      "properties": { "sourceId": "custom-marker-diamond-list" },
                      "children": [
                        {
                          "type": "list-item",
                          "content": "Grandchild item uses the third-level diamond marker.",
                          "properties": { "sourceId": "custom-marker-diamond-one" }
                        }
                      ]
                    }
                  ]
                },
                {
                  "type": "list-item",
                  "content": "Second nested item keeps the same custom marker literal.",
                  "properties": { "sourceId": "custom-marker-check-two" }
                }
              ]
            }
          ]
        },
        {
          "type": "list-item",
          "content": "Second root item proves custom literals do not become authored body text.",
          "properties": { "sourceId": "custom-marker-root-two" },
          "children": [
            {
              "type": "list",
              "list": {
                "kind": "ordered",
                "markerText": "Q:",
                "indent": 24,
                "markerWidth": 16,
                "markerGap": 6
              },
              "properties": { "sourceId": "custom-marker-override-list" },
              "children": [
                {
                  "type": "list-item",
                  "content": "Explicit override uses a question marker instead of inherited level defaults.",
                  "properties": { "sourceId": "custom-marker-question-one" }
                }
              ]
            }
          ]
        }
      ]
    }
  ]
}
