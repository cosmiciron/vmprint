                }
              }
            ]
          },
          "height": 36,
          "kind": "page-region",
          "role": "header",
          "selector": "default",
          "width": 246,
          "x": 57,
          "y": 16
        }
      },
      "source": {
        "path": "elements[21]"
      },
      "sourceType": "chapter-title",
      "style": {
        "fontSize": 16,
        "fontWeight": "bold",
        "hyphenation": "off",
        "keepWithNext": true,
        "marginBottom": 20,
        "marginTop": 36,
        "pageBreakBefore": true,
        "textAlign": "center"
      }
    },
    {
      "allowLineSplit": true,
      "content": "The epilogue's running head is a per-page override that renders the physicalPageNumber token directly, independent of whether the footer renders a logical number on the same page. Both tokens resolve in the same late pass, after all pagination decisions are settled.",
      "keepWithNext": false,
      "kind": "flow-block",
      "overflowPolicy": "clip",
      "pageBreakBefore": false,
      "source": {
        "path": "elements[22]"
      },
      "sourceType": "p",
      "style": {
        "allowLineSplit": true,
        "marginBottom": 9,
        "orphans": 2,
        "widows": 2
      }
    },
    {
      "allowLineSplit": true,
      "content": "Region rendering is a second pass over the paginated output. The first pass places flow content into pages; the second resolves headers, footers, and per-page overrides. This sequencing allows regions to reference page-specific data without entangling the pagination algorithm.",
      "keepWithNext": false,
      "kind": "flow-block",
      "overflowPolicy": "clip",
      "pageBreakBefore": false,
      "source": {
        "path": "elements[23]"
      },
      "sourceType": "p",
      "style": {
        "allowLineSplit": true,
        "marginBottom": 9,
        "orphans": 2,
        "widows": 2
      }
    },
    {
      "allowLineSplit": true,
      "content": "The footer on this page is suppressed by a pageOverrides declaration on this paragraph—the first flow element to land on a new page. No folio line is rendered, and the logical page counter does not advance. The engine increments the counter only when the pageNumber token appears in a rendered region.",
      "keepWithNext": false,
      "kind": "flow-block",
      "overflowPolicy": "clip",
      "pageBreakBefore": true,
      "pageOverrides": {
        "footer": null
      },
      "source": {
        "path": "elements[24]"
      },
      "sourceType": "p",
      "style": {
        "allowLineSplit": true,
        "marginBottom": 9,
        "orphans": 2,
        "pageBreakBefore": true,
        "widows": 2
      }
    },
    {
      "allowLineSplit": true,
      "content": "Page regions are always optional. A document without any header or footer definition is valid and renders cleanly. The constructs exercised here—firstPage suppression, recto and verso selectors, per-page overrides, and token substitution—compose freely. Any subset is sufficient; any combination is legal.",
      "keepWithNext": false,
      "kind": "flow-block",
      "overflowPolicy": "clip",
      "pageBreakBefore": false,
      "source": {
        "path": "elements[25]"
      },
      "sourceType": "p",
      "style": {
        "allowLineSplit": true,
        "marginBottom": 9,
        "orphans": 2,
        "widows": 2
      }
    }
