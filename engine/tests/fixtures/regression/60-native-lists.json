{
  "documentVersion": "1.1",
  "layout": {
    "pageSize": {
      "width": 260,
      "height": 220
    },
    "margins": {
      "top": 28,
      "right": 28,
      "bottom": 28,
      "left": 28
    },
    "fontFamily": "Arimo",
    "fontSize": 12,
    "lineHeight": 1.25
  },
  "fonts": {
    "regular": "Arimo"
  },
  "styles": {
    "h1": {
      "fontSize": 18,
      "fontWeight": "bold",
      "marginBottom": 10,
      "keepWithNext": true
    },
    "p": {
      "marginBottom": 8
    },
    "list": {
      "marginTop": 2,
      "marginBottom": 10
    },
    "list-item": {
      "marginBottom": 6,
      "allowLineSplit": true
    },
    "list-marker": {
      "color": "#444444"
    }
  },
  "elements": [
    {
      "type": "h1",
      "content": "Native Lists"
    },
    {
      "type": "list",
      "content": "",
      "list": {
        "kind": "unordered",
        "indent": 24,
        "markerWidth": 14,
        "markerGap": 10
      },
      "properties": {
        "sourceId": "unordered-list"
      },
      "children": [
        {
          "type": "list-item",
          "content": "Bullets are generated by the engine, not authored as text.",
          "properties": {
            "sourceId": "unordered-one"
          }
        },
        {
          "type": "list-item",
          "content": "",
          "properties": {
            "sourceId": "unordered-rich"
          },
          "children": [
            {
              "type": "text",
              "content": "Inline "
            },
            {
              "type": "text",
              "content": "formatting",
              "properties": {
                "style": {
                  "fontWeight": "bold"
                }
              }
            },
            {
              "type": "text",
              "content": " survives inside a native list item."
            }
          ]
        },
        {
          "type": "list-item",
          "content": "A long bullet wraps under the item text rather than under the marker, demonstrating the hanging indent geometry that an editor can later depend on for selection and mutation operations.",
          "properties": {
            "sourceId": "unordered-wrap"
          }
        }
      ]
    },
    {
      "type": "p",
      "content": "The ordered sequence below starts at 3, crosses a page boundary, and does not author marker text."
    },
    {
      "type": "list",
      "content": "",
      "list": {
        "kind": "ordered",
        "markerStyle": "decimal",
        "start": 3,
        "indent": 28,
        "markerWidth": 18,
        "markerGap": 10
      },
      "properties": {
        "sourceId": "ordered-list"
      },
      "children": [
        {
          "type": "list-item",
          "content": "Third step begins the authored sequence.",
          "properties": {
            "sourceId": "ordered-three"
          }
        },
        {
          "type": "list-item",
          "content": "Fourth step continues with automatic numbering.",
          "properties": {
            "sourceId": "ordered-four"
          }
        },
        {
          "type": "list-item",
          "content": "Fifth step is deliberately wordy so the list has enough body to paginate in a deterministic way while keeping numbering attached to the engine structure.",
          "properties": {
            "sourceId": "ordered-five"
          }
        },
        {
          "type": "list-item",
          "content": "Sixth step should retain its marker after the continuation.",
          "properties": {
            "sourceId": "ordered-six"
          }
        },
        {
          "type": "list-item",
          "content": "Seventh step closes the sequence on a later page.",
          "properties": {
            "sourceId": "ordered-seven"
          }
        }
      ]
    }
  ]
}
