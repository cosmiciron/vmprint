  "elements": [
    { "type": "h1", "content": "Native Lists Inside Contained Shapes" },
    {
      "type": "p",
      "content": "The lists below invert exclusion logic: the shape is the allowed writing room, and generated list markers must stay attached to the item bodies while the bodies fill the interior lanes."
    },
    {
      "type": "list",
      "list": { "kind": "ordered", "markerStyle": "decimal", "indent": 24, "markerWidth": 14, "markerGap": 5 },
      "properties": {
        "sourceId": "contained-circle-list",
        "space": { "kind": "contain", "shape": "circle", "overflow": "stash" },
        "style": {
          "width": 220,
          "height": 190,
          "padding": 8,
          "backgroundColor": "#eeeeee",
          "borderWidth": 1,
          "borderColor": "#d4d4d4",
          "marginBottom": 18
        }
      },
      "children": [
        {
          "type": "list-item",
          "content": "First contained ordered item begins near the crown, widens through the circular middle, and keeps its marker generated by the list actor.",
          "properties": { "sourceId": "contained-circle-one" }
        },
        {
          "type": "list-item",
          "content": "Second item proves numbering continues while the item body follows the allowed interior lane instead of a rectangular fallback.",
          "properties": { "sourceId": "contained-circle-two" }
        }
      ]
    },
    {
      "type": "list",
      "list": { "kind": "unordered", "markerStyle": "square", "indent": 24, "markerWidth": 12, "markerGap": 5 },
      "properties": {
        "sourceId": "contained-polygon-list",
        "space": {
          "kind": "contain",
          "shape": "polygon",
          "path": "M24,0 L196,0 L196,34 L142,34 L142,72 L196,72 L196,132 L128,132 L128,178 L196,178 L196,220 L24,220 L0,112 Z",
          "overflow": "stash"
        },
        "style": {
          "width": 220,
          "height": 220,
          "padding": 8,
          "backgroundColor": "#eeeeee",
          "borderWidth": 1,
          "borderColor": "#d4d4d4"
        }
      },
      "children": [
        {
          "type": "list-item",
          "content": "Polygon item settles through steps and shelves while the generated square marker remains structural.",
          "properties": { "sourceId": "contained-polygon-one" }
        },
        {
          "type": "list-item",
          "content": "Second polygon item keeps the same native list vocabulary while accepting jagged contained lanes.",
          "properties": { "sourceId": "contained-polygon-two" }
        }
