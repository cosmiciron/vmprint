          {
            "allowLineSplit": true,
            "content": "This paragraph appears after the full-width column-span element above. Column flow resets to column one below the span: content begins a fresh three-column arrangement whose top edge aligns with the bottom of the section-break banner. The story packager emits the spanning element at the full story width and then resumes the per-column layout loop from column zero, using the span bottom as the new cursor origin.",
            "keepWithNext": false,
            "kind": "flow-block",
            "overflowPolicy": "clip",
            "pageBreakBefore": false,
            "source": {
