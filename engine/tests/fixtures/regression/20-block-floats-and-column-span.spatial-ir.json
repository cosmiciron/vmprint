            "sourceType": "body",
            "style": {
              "allowLineSplit": true,
              "marginBottom": 10,
              "orphans": 2,
              "textAlign": "justify",
              "widows": 2
            }
          },
          {
            "align": "left",
            "content": {
              "allowLineSplit": true,
              "content": "Text wraps around any block element, not just images.",
              "keepWithNext": false,
              "kind": "flow-block",
              "overflowPolicy": "clip",
              "pageBreakBefore": false,
              "source": {
