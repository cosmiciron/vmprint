              "orphans": 2,
              "textAlign": "justify",
              "widows": 2
            }
          },
          {
            "allowLineSplit": true,
            "content": "A second paragraph confirms the spatial state is cleanly reset after the float clears and the subsequent content sees no residual narrowing.",
