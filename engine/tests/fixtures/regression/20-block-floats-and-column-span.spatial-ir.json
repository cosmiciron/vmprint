        "items": [
          {
            "allowLineSplit": true,
            "content": "The layout engine now supports floating any block element within a story, not just images. A pull-quote, call-out, or sidebar can anchor at the current text cursor and let surrounding body copy wrap around it naturally. Obstacle registration works identically to image floats: the block's bounding box is recorded in the SpatialMap, and the per-line interval resolver carves out the appropriate horizontal space for every line that overlaps the float vertically.",
            "keepWithNext": false,
            "kind": "flow-block",
            "overflowPolicy": "clip",
            "pageBreakBefore": false,
            "source": {
              "path": "elements[2].children.segment[0][0]",
              "sourceId": "intro-para"
