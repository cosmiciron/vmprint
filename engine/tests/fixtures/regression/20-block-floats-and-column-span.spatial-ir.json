              "textAlign": "justify",
              "widows": 2
            }
          },
          {
            "allowLineSplit": true,
            "content": "A second paragraph after the span confirms that multi-paragraph flow continues correctly across all three columns. The spanning element does not discard or restart any column state beyond advancing the cursor: obstacles registered before the span remain correctly projected to their columns, and the column count is unchanged.",
