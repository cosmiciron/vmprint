              "orphans": 2,
              "widows": 2
            }
          },
          {
            "allowLineSplit": true,
            "content": "When the story spans multiple pages, any absolute image that straddles the page break is moved entirely to the next page. Publication-quality layout demands clean image boundaries: no clipping, no partial rendering mid-image.",
