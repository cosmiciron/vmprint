          {
            "allowLineSplit": true,
            "content": "Story-absolute images are pinned at fixed story-local coordinates, independent of the text flow. The burgundy rectangle at upper right was declared as the very first child of this story element and was registered in the SpatialMap during Pass 1 — before a single word of body text was placed. All text from the story’s origin automatically pours around it into the remaining column width to its left.",
            "keepWithNext": false,
            "kind": "flow-block",
            "overflowPolicy": "clip",
            "pageBreakBefore": false,
            "source": {
