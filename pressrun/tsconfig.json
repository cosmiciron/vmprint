{
    "compilerOptions": {
        "target": "ES2020",
        "module": "preserve",
        "moduleResolution": "bundler",
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "types": ["node"],
        "paths": {
            "@vmprint/contracts": [
                "../contracts/src/index.ts"
            ],
            "@vmprint/engine": [
                "../engine/src/index.ts"
            ]
        }
    },
    "include": [
        "src/**/*",
        "../engine/src/fontkit.d.ts"
    ],
    "exclude": [
        "node_modules"
    ]
}
