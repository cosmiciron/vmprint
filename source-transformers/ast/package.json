{
  "name": "@vmprint/source-transformer-ast",
  "version": "0.3.0",
  "description": "Compatibility AST SourceTransformer for VMPrint. Bridges legacy document JSON into engine-ready inputs during the Spatial IR migration.",
  "author": "cosmiciron",
  "license": "Apache-2.0",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "tsx": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "source": "src/index.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@vmprint/contracts": "file:../../contracts",
    "@vmprint/engine": "file:../../engine"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "rimraf": "^6.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.7.3"
  }
}
