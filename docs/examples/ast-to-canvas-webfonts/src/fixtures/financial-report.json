      "zones": [
        {
          "id": "narrative",
          "elements": [
            {
              "type": "body",
              "content": "Asset Management continues to be the firm\u2019s primary growth engine. AUM reached $14.2 billion at quarter end, up $1.4 billion from Q3 2025, driven by $2.1 billion in gross inflows partially offset by $0.7 billion in redemptions. Management fee revenue grew 15.1%, reflecting both the AUM expansion and a modest repricing of institutional mandates completed in July."
            },
            {
              "type": "body",
              "content": "Advisory Services posted $10.8 million in revenue, a 6.1% increase, as M&A advisory activity rebounded in the second half. The pipeline entering Q1 2026 includes seven mandates with aggregate deal value exceeding $3.4 billion."
            },
            {
              "type": "body",
              "content": "Principal Investments contributed $6.3 million, with realized gains of $4.1 million on two portfolio exits in the quarter. The remaining portfolio is carried at $41.7 million, representing an estimated 1.6x gross MOIC."
            }
          ]
