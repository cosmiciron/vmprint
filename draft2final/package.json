{
  "name": "@draft2final/cli",
  "version": "0.2.0",
  "description": "Thin transmuter-first Markdown-to-PDF orchestrator for VMPrint.",
  "author": "cosmiciron",
  "license": "Apache-2.0",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "draft2final": "dist/cli.js"
  },
  "files": [
    "dist",
    "config",
    "themes"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx --conditions tsx src/cli.ts",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@vmprint/contracts": "file:../contracts",
    "@vmprint/context-pdf": "file:../contexts/pdf",
    "@vmprint/engine": "file:../engine",
    "@vmprint/local-fonts": "file:../font-managers/local",
    "@vmprint/transmuter-mkd-academic": "file:../transmuters/mkd-academic",
    "@vmprint/transmuter-mkd-literature": "file:../transmuters/mkd-literature",
    "@vmprint/transmuter-mkd-manuscript": "file:../transmuters/mkd-manuscript",
    "@vmprint/transmuter-mkd-mkd": "file:../transmuters/mkd-mkd",
    "@vmprint/transmuter-mkd-screenplay": "file:../transmuters/mkd-screenplay"
  },
  "devDependencies": {
    "@types/node": "^22.13.1",
    "rimraf": "^6.1.3",
    "tsx": "^4.21.0",
    "typescript": "^5.7.3"
  }
}
