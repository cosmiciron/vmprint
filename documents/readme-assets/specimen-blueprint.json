        { "type": "text", "content": "\u2002" },
        { "type": "text", "content": "10 pt bold", "properties": { "style": { "fontFamily": "Arimo", "fontWeight": 700, "fontSize": 10, "color": "#2d1a08" } } },
        { "type": "text", "content": "\u2002" },
        { "type": "text", "content": "16 pt Tinos", "properties": { "style": { "fontFamily": "Tinos", "fontSize": 16, "fontWeight": 700, "color": "#7a3a52" } } },
        { "type": "text", "content": "\u2002" },
        { "type": "text", "content": "8 pt again", "properties": { "style": { "fontFamily": "Tinos", "fontStyle": "italic", "fontSize": 8, "color": "#9c8060" } } },
