    {
      "type": "p2kicker",
      "content": "MIXED SCRIPT  \u00b7  OPTICAL SCALING  \u00b7  BASELINE STABILITY"
    },
    {
      "type": "mixedBlock",
      "content": "",
      "properties": { "sourceId": "mixed-lead" },
      "children": [
        { "type": "text", "content": "The contract holds across every writing system: " },
        { "type": "text", "content": "Precision", "properties": { "style": { "fontFamily": "Tinos", "fontSize": 14, "fontWeight": 700, "color": "#1a0800" } } },
        { "type": "inline-box", "content": "LATIN", "properties": { "style": { "fontSize": 5.0, "fontFamily": "Noto Sans", "fontWeight": 700, "color": "#fdf6e3", "backgroundColor": "#6b5040", "paddingLeft": 2.5, "paddingRight": 2.5, "paddingTop": 0.5, "paddingBottom": 0.5, "borderWidth": 0, "verticalAlign": "baseline", "baselineShift": -2, "inlineMarginLeft": 2, "inlineMarginRight": 5 } } },
        { "type": "text", "content": " \u00b7 " },
        { "type": "text", "content": "\u0627\u0644\u062f\u0650\u0642\u0651\u0629", "properties": { "style": { "fontFamily": "Noto Sans Arabic", "fontSize": 14, "direction": "rtl", "lang": "ar", "color": "#7a3a18" } } },
        { "type": "inline-box", "content": "ARABIC", "properties": { "style": { "fontSize": 5.0, "fontFamily": "Noto Sans", "fontWeight": 700, "color": "#fdf6e3", "backgroundColor": "#7a3a18", "paddingLeft": 2.5, "paddingRight": 2.5, "paddingTop": 0.5, "paddingBottom": 0.5, "borderWidth": 0, "verticalAlign": "baseline", "baselineShift": -2, "inlineMarginLeft": 2, "inlineMarginRight": 5 } } },
        { "type": "text", "content": " \u00b7 " },
        { "type": "text", "content": "\u0e04\u0e27\u0e32\u0e21\u0e41\u0e21\u0e48\u0e19\u0e22\u0e33", "properties": { "style": { "fontFamily": "Noto Sans Thai", "fontSize": 14, "lang": "th", "color": "#1a4a1a" } } },
        { "type": "inline-box", "content": "THAI", "properties": { "style": { "fontSize": 5.0, "fontFamily": "Noto Sans", "fontWeight": 700, "color": "#fdf6e3", "backgroundColor": "#1a4a1a", "paddingLeft": 2.5, "paddingRight": 2.5, "paddingTop": 0.5, "paddingBottom": 0.5, "borderWidth": 0, "verticalAlign": "baseline", "baselineShift": -2, "inlineMarginLeft": 2, "inlineMarginRight": 5 } } },
        { "type": "text", "content": " \u00b7 " },
        { "type": "text", "content": "\u7cbe\u78ba", "properties": { "style": { "fontFamily": "Noto Sans JP", "fontSize": 14, "lang": "zh", "color": "#1a1a5a" } } },
        { "type": "inline-box", "content": "CJK", "properties": { "style": { "fontSize": 5.0, "fontFamily": "Noto Sans", "fontWeight": 700, "color": "#fdf6e3", "backgroundColor": "#1a1a5a", "paddingLeft": 2.5, "paddingRight": 2.5, "paddingTop": 0.5, "paddingBottom": 0.5, "borderWidth": 0, "verticalAlign": "baseline", "baselineShift": -2, "inlineMarginLeft": 2, "inlineMarginRight": 5 } } },
        { "type": "text", "content": " \u00b7 " },
        { "type": "text", "content": "\u0938\u091f\u0940\u0915\u0924\u093e", "properties": { "style": { "fontFamily": "Noto Sans Devanagari", "fontSize": 14, "lang": "hi", "color": "#3a1a5a" } } },
        { "type": "inline-box", "content": "DEVA", "properties": { "style": { "fontSize": 5.0, "fontFamily": "Noto Sans", "fontWeight": 700, "color": "#fdf6e3", "backgroundColor": "#3a1a5a", "paddingLeft": 2.5, "paddingRight": 2.5, "paddingTop": 0.5, "paddingBottom": 0.5, "borderWidth": 0, "verticalAlign": "baseline", "baselineShift": -2, "inlineMarginLeft": 2, "inlineMarginRight": 5 } } },
