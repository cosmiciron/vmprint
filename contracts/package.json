{
  "name": "@vmprint/contracts",
  "version": "1.0.2",
  "description": "Core interfaces for VMPrint engines, contexts, and font managers.",
  "author": "cosmiciron",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cosmiciron/vmprint.git",
    "directory": "contracts"
  },
  "bugs": {
    "url": "https://github.com/cosmiciron/vmprint/issues"
  },
  "homepage": "https://github.com/cosmiciron/vmprint/tree/main/contracts#readme",
  "keywords": [
    "vmprint",
    "contracts",
    "types",
    "interfaces",
    "font-manager",
    "context",
    "typesetting"
  ],
  "sideEffects": false,
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "!dist/**/*.map"
  ],
  "scripts": {
    "build": "tsup",
    "clean": "rimraf dist"
  },
  "devDependencies": {
    "rimraf": "^6.1.3",
    "tsup": "^8.5.1",
    "typescript": "^5.7.3"
  },
  "publishConfig": {
    "access": "public"
  }
}
