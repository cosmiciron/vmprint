    },
    {
      "type": "action",
      "content": "",
      "children": [
        {
          "type": "text",
          "content": "Antenna forests sway in dry wind as cargo drones thread through narrow lanes. Sirens Doppler below, too far to locate, too close to ignore."
        }
      ],
      "properties": {
        "sourceRange": {
          "lineStart": 56,
          "colStart": 1,
          "lineEnd": 57,
          "colEnd": 62
