      "properties": {
        "keepWithNext": true
      }
    },
    {
      "type": "dialogue-dual-left",
      "content": "",
      "children": [
        {
          "type": "text",
          "content": "If the patch is late, transit collapses by first light."
        }
      ],
      "properties": {
        "paginationContinuation": {
