{
  "name": "@vmprint/preview",
  "version": "1.0.1",
  "description": "Script-first browser preview controller for VMPrint. Renders document pages to caller-owned canvases and supports PDF/SVG export.",
  "author": "cosmiciron",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cosmiciron/vmprint.git",
    "directory": "preview"
  },
  "bugs": {
    "url": "https://github.com/cosmiciron/vmprint/issues"
  },
  "homepage": "https://github.com/cosmiciron/vmprint/tree/main/preview#readme",
  "keywords": [
    "pdf",
    "canvas",
    "preview",
    "svg",
    "document",
    "layout",
    "typesetting",
    "vmprint",
    "browser"
  ],
  "sideEffects": false,
  "main": "dist/index.cjs",
  "module": "dist/index.mjs",
  "types": "dist/types/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "!dist/**/*.map",
    "LICENSE"
  ],
  "scripts": {
    "build": "npm run clean && node scripts/build.mjs",
    "clean": "rimraf dist",
    "prepublishOnly": "npm run build",
    "demo:build": "node scripts/build-demo.mjs",
    "demo:serve": "node scripts/serve-demo.mjs"
  },
  "dependencies": {
    "@vmprint/contracts": "^1.0.2",
    "@vmprint/engine": "^1.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.13.1",
    "@vmprint/context-canvas": "latest",
    "@vmprint/context-pdf-lite": "latest",
    "@vmprint/engine": "file:../engine",
    "@vmprint/web-fonts": "latest",
    "@vmprint/local-fonts": "latest",
    "esbuild": "^0.25.10",
    "rimraf": "^6.1.3",
    "tsx": "^4.20.5",
    "typescript": "^5.7.3"
  },
  "publishConfig": {
    "access": "public"
  }
}
