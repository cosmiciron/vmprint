{
  "name": "@vmprint/preview",
  "version": "1.0.0",
  "description": "Script-first browser preview controller for VMPrint. Renders document pages to caller-owned canvases and supports PDF/SVG export.",
  "author": "cosmiciron",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cosmiciron/vmprint.git",
    "directory": "preview"
  },
  "bugs": {
    "url": "https://github.com/cosmiciron/vmprint/issues"
  },
  "homepage": "https://github.com/cosmiciron/vmprint/tree/main/preview#readme",
  "keywords": [
    "pdf",
    "canvas",
    "preview",
    "svg",
    "document",
    "layout",
    "typesetting",
    "vmprint",
    "browser"
  ],
  "sideEffects": false,
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "tsx": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "LICENSE"
  ],
  "scripts": {
    "build": "npm run clean && tsc",
    "clean": "rimraf dist",
    "prepublishOnly": "npm run build",
    "demo:build": "node scripts/build-demo.mjs",
    "demo:serve": "node scripts/serve-demo.mjs"
  },
  "dependencies": {
    "@vmprint/context-canvas": "file:../contexts/canvas",
    "@vmprint/context-pdf-lite": "file:../contexts/pdf-lite",
    "@vmprint/engine": "file:../engine",
    "@vmprint/local-fonts": "file:../font-managers/local",
    "@vmprint/web-fonts": "file:../font-managers/web"
  },
  "devDependencies": {
    "@types/node": "^22.13.1",
    "esbuild": "^0.25.10",
    "rimraf": "^6.1.3",
    "tsx": "^4.20.5",
    "typescript": "^5.7.3"
  },
  "publishConfig": {
    "access": "public"
  }
}
